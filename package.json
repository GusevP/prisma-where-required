{
  "name": "@gusevp/prisma-where-required",
  "version": "0.0.0-semantically-released",
  "description": "Make certain fields required in where clause for Prisma (Prisma 7 fork)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "author": "GusevP",
  "contributors": [
    "kz-d (original author)"
  ],
  "bin": {
    "prisma-where-required": "./dist/generator.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GusevP/prisma-where-required"
  },
  "keywords": ["prisma", "prisma-7"],
  "scripts": {
    "build": "tsc",
    "generate:prisma": "prisma generate",
    "generate:typeTestFile": "ts-node tests/generateTypeTestFile.ts",
    "test": "npx prisma generate && tsc tests/*.test.ts --noEmit --esModuleInterop --moduleResolution node --target es2020 --strict --skipLibCheck",
    "lint": "eslint ./src"
  },
  "devDependencies": {
    "@types/node": "^20.4.1",
    "@typescript-eslint/eslint-plugin": "^6.2.1",
    "@typescript-eslint/parser": "^6.2.1",
    "eslint": "^8.46.0",
    "prisma": "^7.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6",
    "@prisma/client": "^7.0.0"
  },
  "dependencies": {
    "@prisma/generator-helper": "^7.0.0",
    "@prisma/internals": "^7.0.0",
    "ts-morph": "^23.0.0"
  },
  "peerDependencies": {
    "@prisma/client": ">= 7.0"
  }
}
