// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// Sibling of `schema.prisma` for the `test:includes` script. Differs only in
// the `strictness` value. Keep model definitions in sync with `schema.prisma`.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

generator whereRequired {
  provider       = "ts-node ./src/generator.ts"
  debug          = true
  requiredFields = ["organizationId"]
  strictness     = "includes"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             Int     @id @default(autoincrement())
  email          String  @unique
  organizationId Int     /// @where-required
  name           String?
  posts          Post[]
  memos          Memo[]
}

model UserPost {
  id             Int    @id @default(autoincrement())
  title          String
  organizationId Int
}

model Post {
  id             Int     @id @default(autoincrement())
  title          String
  content        String?
  published      Boolean @default(false)
  author         User    @relation(fields: [authorId], references: [id])
  authorId       Int
  organizationId Int
}

model Tag {
  id    Int    @id @default(autoincrement())
  label String
}

model Memo {
  id             Int   @id @default(autoincrement())
  content        String
  organizationId Int?  /// @where-required
  ownerId        Int?
  owner          User? @relation(fields: [ownerId], references: [id])
}
